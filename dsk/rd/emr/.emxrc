//USER=emex
//HOME=/home/$USER

var lsblk      = ("/bin/lsblk.elf")
var desktop    = ("/emr/system/desktop/desktop.elf")
var bg_test    = ("/emr/system/sinfo.elf")
var bg_test2   = ("/emr/system/libraries/cursor.elf")
var login_path = ("/emr/system/login.elf")
var shell_path = (ep: "/home/emex/apps/shell.emx")

exec /emr/system/system.emx/initd.elf
wait 1

exec -bg desktop
exec login_path

//exec -bg bg_test
//exec -bg bg_test


// last things which should happen
//exec login_path
exec -f"ep" shell_path
